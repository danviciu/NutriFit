    "@supabase/supabase-js": "^2.97.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.6",
